{
  "version": 2,
  "builds": [
    {
      "src": "EasyPortrait/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/portrait/(.*)",
      "dest": "/EasyPortrait/dist/$1"
    },
    {
      "src": "/portrait",
      "dest": "/EasyPortrait/dist/index.html"
    },
    {
      "src": "/srt-editor/(.*)",
      "dest": "/srt-editor/$1"
    },
    {
      "src": "/srt-editor",
      "dest": "/srt-editor/index.html"
    },
    {
      "src": "/(logo\\.png|ads\\.txt|robots\\.txt|sitemap\\.xml|google.*\\.html|privacy\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
